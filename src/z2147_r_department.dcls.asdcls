@EndUserText.label: 'Department (Access Control)'
@MappingRole: true
define role Z2147_R_DEPARTMENT {
     grant select on Z2147_R_Department
  where ( Id) 
      = aspect pfcg_auth(
                  /LRN/DPMNT, 
                  /LRN/DPMNT, 
                
                  ACTVT = '03'
               );                        
}